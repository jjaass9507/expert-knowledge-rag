# LLM 後端：預設後端 id（pensieve / openai / stub）。平台頂部可即時切換並持久化。
EKR_LLM=pensieve

# 後端一：內部 Pensieve API
PENSIEVE_LABEL=Pensieve · GPT-4.1-mini
PENSIEVE_URL=
PENSIEVE_TOKEN=
EMPNO=
# building 為路由變數，值 option 走可自訂 system/human prompt 的路徑
PENSIEVE_BUILDING=option
PENSIEVE_VERIFY_SSL=false
PENSIEVE_TIMEOUT=300

# 後端二：OpenAI 相容 /chat/completions API
OPENAI_LABEL=內部 OpenAI 相容 API
OPENAI_API_URL=https://10.10.23.120:4231/public/kits/openai/v1/chat/completions
OPENAI_MODEL=
OPENAI_API_KEY=
OPENAI_VERIFY_SSL=false
OPENAI_TIMEOUT=300
# 選用：閘道支援時才開，送 response_format={"type":"json_object"} 提升 JSON 穩定度
OPENAI_JSON_MODE=false

# 語音轉文字（Phase 2）；離線或純文字流程可設 EKR_ASR=stub
EKR_ASR=whisper
WHISPER_MODEL=large-v3
WHISPER_LANG=zh
# 專業術語/設備型號清單，做 prompt bias 提升現場錄音辨識率（選填）
WHISPER_PROMPT=

# 向量化（Phase 3）；預設 off 不向量化。設 on 並填妥下列項目以啟用核准即索引
EKR_VECTOR=off
EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_cards
