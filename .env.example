# LLM 結構化呼叫設定（OpenAI 相容 /chat/completions 介面）
# 正式環境填本地推論伺服器或雲端 API 端點；測試或離線可改用 EKR_LLM=stub
EKR_LLM=api
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gemma2
LLM_TEMPERATURE=0.2

# 語音轉文字（Phase 2）；離線或純文字流程可設 EKR_ASR=stub
EKR_ASR=whisper
WHISPER_MODEL=large-v3
WHISPER_LANG=zh
# 專業術語/設備型號清單，做 prompt bias 提升現場錄音辨識率（選填）
WHISPER_PROMPT=

# 向量化（Phase 3）；預設 off 不向量化。設 on 並填妥下列項目以啟用核准即索引
EKR_VECTOR=off
EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_cards
